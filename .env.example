# ──────────────────────────────────────────────────────────────
# Knot Code – Environment Variables
# ──────────────────────────────────────────────────────────────

# GitHub OAuth App Client ID (for device-flow auth)
# Create at: https://github.com/settings/developers
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# YouTube Data API v3 key (enables YouTube search)
# Create at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in the APIs & Services library
NEXT_PUBLIC_YOUTUBE_API_KEY=
